# Recorded tape artifacts are large + regenerated; keep them out of git.
# A curated sample tape lives under docs/sample-tape/ (committed by hand).
tapes/*
!tapes/.gitkeep

# Per-scene intermediate clips — finish-tape concatenates them into
# master.{mp4,gif}, only the masters are evidence worth checking in.
docs/tapes/*/scene-*.mp4

# Ephemeral SSH material the orchestrator may generate.
fixtures/*
!fixtures/.gitkeep

# Rust / build
target/
**/*.rs.bk

# Node / Bun
node_modules/

.DS_Store
feature-probe-report.json
