# Recorded tape artifacts are large + regenerated; keep them out of git.
# A curated sample tape lives under docs/sample-tape/ (committed by hand).
tapes/*
!tapes/.gitkeep

# Per-scene intermediate clips — finish-tape concatenates them into
# master.{mp4,gif}, only the masters are evidence worth checking in.
docs/tapes/*/scene-*.mp4

# The continuous-mode pipeline writes a raw master.mov before remuxing
# to mp4 and converting to gif. The mp4 is what reviewers play inline;
# the mov is a lossless intermediate that bloats the repo unnecessarily.
docs/tapes/*/master.mov

# Hidden placeholder file the continuous recorder touches to ensure
# the tape dir exists before the recorder starts.
docs/tapes/*/.placeholder

# Ephemeral SSH material the orchestrator may generate.
fixtures/*
!fixtures/.gitkeep

# Rust / build
target/
**/*.rs.bk

# Node / Bun
node_modules/

.DS_Store
feature-probe-report.json
